<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=1024, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta
      name="description"
      content="Ecrits — Ecrits for small-business operators. An AI agent grills you before it edits; 법제처 citations are verified; no silent rewrites."
    />
    <.live_title default="Ecrits" suffix=" · Ecrits">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <%!-- Observex runtime (markdown preview math/TikZ islands). Must come
          before app.js: both are `defer`, so they execute in document order
          and the ObservexPreview hook finds window.Observex ready. Assets are
          installed by `mix assets.observex` (see assets.setup alias). --%>
    <script defer phx-track-static type="text/javascript" src={~p"/observex/observex.js"}>
    </script>
    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/app.js?v=#{static_asset_version("/assets/js/app.js")}"}
    >
    </script>
  </head>
  <body class="min-h-full min-w-[1024px] bg-base-100 text-base-content antialiased font-sans">
    {@inner_content}
  </body>
</html>
